# Environment Variables Template for The Everything Shop Microservices
# Copy this file to .env in each service directory and fill in the values

# ==================== NODE & SERVER ====================
NODE_ENV=development
PORT=3000

# ==================== DATABASE ====================
DATABASE_URL=postgresql://user:password@localhost:5432/service_db

# ==================== RABBITMQ ====================
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# ==================== REDIS ====================
REDIS_URL=redis://localhost:6379

# ==================== JWT ====================
JWT_SECRET=your-super-secret-key-change-in-production
JWT_PUBLIC_KEY=your-public-key
JWT_EXPIRY=24h

# ==================== SERVICES ====================
# Used for inter-service communication (REST calls)
AUTH_SERVICE_URL=http://localhost:3001
ACCOUNT_SERVICE_URL=http://localhost:3002
CATALOG_SERVICE_URL=http://localhost:3003
CART_SERVICE_URL=http://localhost:3004
ORDER_SERVICE_URL=http://localhost:3005
PAYMENT_SERVICE_URL=http://localhost:3006
REPORT_SERVICE_URL=http://localhost:3007
NOTIFICATION_SERVICE_URL=http://localhost:3008

# ==================== PAYMENT GATEWAYS ====================
# VNPAY Configuration
VNPAY_MERCHANT_ID=your-merchant-id
VNPAY_SECURE_SECRET=your-secure-secret
VNPAY_RETURN_URL=http://localhost/api/payments/vnpay-callback

# Stripe Configuration
STRIPE_API_KEY=your-stripe-api-key
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-webhook-secret

# Momo Configuration
MOMO_PARTNER_CODE=your-partner-code
MOMO_ACCESS_KEY=your-access-key
MOMO_SECRET_KEY=your-secret-key

# ==================== EMAIL SERVICE ====================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@teleshop.com

# ==================== LOGGING ====================
LOG_LEVEL=info
LOG_FORMAT=json

# ==================== CORS ====================
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# ==================== API GATEWAY ====================
API_GATEWAY_URL=http://localhost
