{
  "name": "order-service",
  "version": "1.0.0",
  "description": "Order management microservice for The Everything Shop",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "lint": "eslint src --ext .ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:reset": "prisma migrate reset",
    "db:seed": "prisma db seed"
  },
  "dependencies": {
    "@prisma/client": "^5.7.1",
    "@teleshop/common": "file:../../shared",
    "express": "^5.0.0",
    "pino": "^8.16.2",
    "pino-http": "^8.5.1",
    "express-validator": "^7.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "@typescript-eslint/eslint-plugin": "^6.16.0",
    "@typescript-eslint/parser": "^6.16.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "prisma": "^5.7.1"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
