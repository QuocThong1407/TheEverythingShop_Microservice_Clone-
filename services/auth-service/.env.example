NODE_ENV=development
PORT=3001

# Database
DATABASE_URL=postgresql://auth_user:auth_password@localhost:5432/auth_db

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# JWT
JWT_SECRET=dev-jwt-secret-key-please-change-in-production
JWT_PUBLIC_KEY=dev-public-key
JWT_EXPIRY=24h

# Services URLs
ACCOUNT_SERVICE_URL=http://localhost:3002
CATALOG_SERVICE_URL=http://localhost:3003
ORDER_SERVICE_URL=http://localhost:3005
PAYMENT_SERVICE_URL=http://localhost:3006

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:5173,http://localhost
